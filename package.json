{
	"name": "@recipes-api/source",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"update-cdk": "nx run cdk:update",
		"codegen": "nx run-many --target=codegen",
		"prebuild": "npm run codegen",
		"build": "nx run-many --target=build --skip-nx-cache",
		"test": "nx run-many --target=test",
		"lint": "nx run-many --target=lint",
		"lint:fix": "nx run-many --target=lint --all --fix",
		"serve": "nx run lambda-rest-endpoints:serve",
		"manual-takedown": "nx run tools-manual-takedown:run",
		"commandline-reindex": "nx run lambda-recipes-responder:commandline-reindex -- ",
		"nx": "nx"
	},
	"private": true,
	"dependencies": {
		"@aws-sdk/client-cloudwatch": "^3.980.0",
		"@aws-sdk/client-dynamodb": "^3.980.0",
		"@aws-sdk/client-eventbridge": "^3.980.0",
		"@aws-sdk/client-s3": "^3.980.0",
		"@aws-sdk/client-sns": "^3.980.0",
		"@aws-sdk/client-ssm": "^3.980.0",
		"@aws-sdk/client-sts": "^3.1007.0",
		"@aws-sdk/credential-providers": "^3.980.0",
		"@codegenie/serverless-express": "^5.0.0",
		"@google-cloud/storage": "^7.19.0",
		"@guardian/content-api-models": "^44.0.0",
		"@guardian/feast-multiplatform-library": "^18.0.0",
		"aws-lambda": "^1.0.7",
		"axios": "^1.16.1",
		"body-parser": "^2.3.0",
		"commander": "^15.0.0",
		"csv-parse": "^7.0.0",
		"date-fns": "^4.4.0",
		"express": "5.2.1",
		"express-async-handler": "^1.2.0",
		"i18n-iso-countries": "^7.14.0",
		"lodash-es": "4.18.1",
		"node-fetch": "^3.3.2",
		"qrcode": "^1.5.4",
		"tslib": "^2.3.0",
		"uuid": "^14.0.1",
		"zod": "^4.4.3"
	},
	"prettier": "@guardian/prettier",
	"eslintConfig": {
		"root": true,
		"env": {
			"node": true,
			"jest": true
		},
		"extends": [
			"@guardian/eslint-config-typescript"
		],
		"parserOptions": {
			"ecmaVersion": 2020,
			"sourceType": "module"
		},
		"plugins": [
			"@typescript-eslint"
		],
		"rules": {
			"@typescript-eslint/no-inferrable-types": 0,
			"import/no-namespace": 2
		},
		"ignorePatterns": [
			"**/*.js",
			"node_modules",
			"cdk.out",
			".eslintrc.js",
			"jest.config.js"
		]
	},
	"optionalDependencies": {
		"@nx/nx-linux-x64-gnu": "23.0.1"
	},
	"devDependencies": {
		"@guardian/cdk": "^63.6.1",
		"@guardian/eslint-config-typescript": "^12.0.0",
		"@guardian/prettier": "11.0.0",
		"@guardian/tsconfig": "^2.0.0",
		"@nx/esbuild": "23.0.1",
		"@nx/eslint": "23.0.1",
		"@nx/eslint-plugin": "23.0.1",
		"@nx/jest": "23.0.1",
		"@nx/js": "23.0.1",
		"@nx/node": "23.0.1",
		"@nx/workspace": "23.0.1",
		"@swc/core": "1.15.8",
		"@types/aws-lambda": "^8.10.125",
		"@types/body-parser": "^1.19.5",
		"@types/ejs": "^3.1.5",
		"@types/express": "4.17.25",
		"@types/jest": "30.0.0",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "26.0.1",
		"@types/node-fetch": "^2.6.12",
		"@types/qrcode": "^1.5.5",
		"@types/uuid": "^10.0.0",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"aws-cdk": "2.1128.1",
		"aws-cdk-lib": "^2.241.0",
		"aws-sdk-client-mock": "^4.1.0",
		"constructs": "10.5.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "^5.2.1",
		"jest": "30.0.5",
		"jest-environment-node": "^30.4.1",
		"jest-util": "30.3.0",
		"nx": "23.0.1",
		"prettier": "~3.6.2",
		"quicktype": "^23.2.6",
		"source-map-support": "^0.5.20",
		"ts-jest": "29.4.6",
		"ts-node": "10.9.1",
		"tsconfig-paths": "^4.2.0",
		"typescript": "~6.0.3"
	}
}
